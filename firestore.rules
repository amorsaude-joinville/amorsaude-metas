rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lançamentos: cada usuária só lê e escreve os próprios
    // Gestora, subgestora, coordenadora, líderes e financeiro lêem todos (dashboards/relatórios)
    // - financeiro (Thifani, Leila): leitura ampla, sem permissão de criação/edição/exclusão
    match /lancamentos/{docId} {
      allow read: if request.auth != null &&
        (resource.data.usuario_id == request.auth.uid ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora', 'lider', 'coordenadora', 'recepcionista', 'callcenter', 'lider_callcenter', 'financeiro']);
      allow create: if request.auth != null &&
        request.resource.data.usuario_id == request.auth.uid &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil != 'financeiro';
      // Update: dono do doc OU operadores do kanban (recep/callcenter mudam status
      // link_enviado→pago/recusado) OU liderança/gestão (correções).
      // Financeiro excluído propositalmente (read-only por design).
      allow update: if request.auth != null && (
        resource.data.usuario_id == request.auth.uid ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in [
          'gestor', 'subgestor', 'subgestora',
          'lider', 'lider_callcenter',
          'coordenadora', 'coordenador',
          'recepcionista', 'callcenter'
        ]
      );
      allow delete: if request.auth != null &&
        (resource.data.usuario_id == request.auth.uid ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora', 'lider']);
    }

    // Metas: somente gestora e subgestora escrevem, todos leem
    match /metas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora'];
    }

    // Usuários: cada uma lê o próprio, gestora lê todos.
    // Cada usuária pode criar/atualizar o PRÓPRIO doc (necessário para
    // garantirDocUsuario() popular perfil/nome a partir do mapa hardcoded
    // em USUARIOS) — validamos que o email gravado bate com auth.token.email
    // para evitar troca de identidade. Gestão segue podendo escrever em qualquer doc.
    match /usuarios/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora']);
      allow write: if request.auth != null &&
        ((request.auth.uid == userId &&
          request.resource.data.email == request.auth.token.email) ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora']);
    }

    // Fechamentos: somente gestora e subgestora (mantido para histórico existente)
    match /fechamentos/{docId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora'];
    }

    // Histórico diário da equipe (importação)
    match /historico_equipe/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora'];
    }

    // Histórico diário por colaboradora (importação — dados diários individuais)
    match /historico_diario/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora'];
    }

    // Faturamento diário consolidado da unidade (para dashboard gestora/lider)
    match /faturamentoDiario/{docId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora', 'lider'];
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora'];
    }

    // Feriados: todos os perfis leem (cálculo de dias úteis), gestão e líderes escrevem
    match /feriados/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora', 'lider'];
    }

    // Resumo do Dia (planilha do gestor): doc por data YYYY-MM-DD.
    // Leitura e escrita pra gestor, subgestora e líder de recepção (VE_DASHBOARD).
    match /resumo_diario/{docId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora', 'lider'];
    }

    // Orçamentos (Fase 1): todos os perfis autenticados leem (filtro de visibilidade
    // é aplicado no cliente). Criação só com criado_por_uid == auth.uid.
    // Edição/exclusão pelo dono ou pela liderança (lider, lider_callcenter, gestor, subgestora).
    // Status pode ser alterado por qualquer usuária autenticada (regra simplificada para Fase 1).
    match /orcamentos/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.criado_por_uid == request.auth.uid;
      allow update, delete: if request.auth != null &&
        (resource.data.criado_por_uid == request.auth.uid ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in ['gestor', 'subgestora', 'lider', 'lider_callcenter']);
    }

    // Config de backup: metadata do último backup completo (data, usuário, totais).
    // Doc id = "ultimo". Acesso restrito a perfis que podem operar o backup
    // (mesma lista do botão na UI — VE_BACKUP). Recepcionista/callcenter excluídos.
    match /config_backup/{docId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil in [
          'gestor', 'subgestor', 'subgestora',
          'lider', 'lider_callcenter',
          'coordenadora', 'coordenador',
          'financeiro'
        ];
    }
  }
}
